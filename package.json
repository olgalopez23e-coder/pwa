{
  "name": "pokemon-app",
  "version": "1.0.0",
  "description": "Pokédex App - Frontend + Backend",
  "main": "index.js",
  "scripts": {
    "build": "npm run install-all && cd frontend && npm run build",
    "start": "cd backend-api && npm start",
    "install-frontend": "cd frontend && npm install",
    "install-backend": "cd backend-api && npm install",
    "install-all": "npm run install-frontend && npm run install-backend",
    "postinstall": "npm run install-all"
  },
  "engines": {
    "node": "18.x"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "idb": "^8.0.3",
    "web-push": "^3.6.7"
  }
}
